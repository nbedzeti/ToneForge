    // MARK: - Export Handling
    
    private func handleExportAction() {
        // Check if user can create ringtone
        guard purchaseManager.canCreateRingtone else {
            // Show limit alert with options
            showingLimitAlert = true
            return
        }
        
        // Proceed with export
        trimAndExportAudio()
    }
    
    // MARK: - Watch Rewarded Ad
    
    private func watchRewardedAd() {
        purchaseManager.showRewardedAd { [self] success in
            if success {
                // Show success toast
                if purchaseManager.extraCreationsAvailable > 0 {
                    adSuccessMessage = "🎉 Unlocked 1 ringtone! You now have \(purchaseManager.extraCreationsAvailable) available."
                } else {
                    adSuccessMessage = "✅ Ad watched! \(purchaseManager.adsWatchedForNextUnlock)/3 complete."
                }
                
                showingAdSuccessToast = true
                
                // Hide toast after 3 seconds
                DispatchQueue.main.asyncAfter(deadline: .now() + 3.0) {
                    showingAdSuccessToast = false
                }
                
                // Also show the alert for detailed info
                showingAdRewardAlert = true
            } else {
                // Show error
                alertTitle = "Ad Not Available"
                alertMessage = purchaseManager.adManager?.lastAdError ?? "Unable to load ad. Please try again later or upgrade to Premium for unlimited ringtones."
                showingAlert = true
            }
        }
    }
    
    private func loadAudioAsset(from url: URL) {
        // Create AVAsset from the audio URL
        let asset = AVAsset(url: url)
        self.audioAsset = asset
        
        // Load the duration asynchronously
        Task {
            do {
                // Validate audio format
                guard let track = try await asset.loadTracks(withMediaType: .audio).first else {
                    throw AudioError.noAudioTrack
                }
                
                // Check if format is supported
                let formatDescriptions = try await track.load(.formatDescriptions)
                guard !formatDescriptions.isEmpty else {
                    throw AudioError.unsupportedFormat
                }
                
                let duration = try await asset.load(.duration)
                let seconds = CMTimeGetSeconds(duration)
                
                // Validate duration
                guard seconds > 0 && seconds.isFinite else {
                    throw AudioError.invalidDuration
                }
                
                await MainActor.run {
                    self.audioDuration = seconds
                    self.isAudioLoaded = true
                    
                    // Stop any playing audio
                    self.stopPreview()
                    
                    // Set default end time to min of 30 seconds or total duration
                    self.endTime = min(30, seconds)
                    self.endTimeText = String(format: "%.0f", self.endTime)
                    self.startTime = 0
                    self.startTimeText = "0"
                    
                    // Show success message
                    self.alertTitle = "Success"
                    self.alertMessage = "Audio loaded successfully! Duration: \(formatDuration(seconds))"
                    self.showingAlert = true
                }
            } catch let error as AudioError {
                await MainActor.run {
                    alertTitle = "Audio Error"
                    alertMessage = error.localizedDescription
                    showingAlert = true
                    isAudioLoaded = false
                }
            } catch {
                await MainActor.run {
                    alertTitle = "Error"
                    alertMessage = "Failed to load audio: \(error.localizedDescription)"
                    showingAlert = true
                    isAudioLoaded = false
                }
            }
        }
    }
    
    private func formatDuration(_ duration: TimeInterval) -> String {
        let minutes = Int(duration) / 60
        let seconds = Int(duration) % 60
        return String(format: "%d:%02d", minutes, seconds)
    }
    
    private func validateAndUpdateStartTime(_ text: String) {
        // Stop playback when changing times
        if isPlaying {
            stopPreview()
        }
        
        // Handle empty input
        if text.isEmpty {
            startTime = 0
            return
        }
        
        guard let value = Double(text) else {
            alertTitle = "Invalid Input"
            alertMessage = "Please enter a valid number for start time."
            showingAlert = true
            startTimeText = String(format: "%.1f", startTime)
            return
        }
        
        guard value >= 0 else {
            alertTitle = "Invalid Time"
            alertMessage = "Start time cannot be negative."
            showingAlert = true
            startTimeText = String(format: "%.1f", startTime)
            return
        }
        
        guard value < audioDuration else {
            alertTitle = "Invalid Time"
            alertMessage = "Start time must be less than song duration (\(formatDuration(audioDuration)))."
            showingAlert = true
            startTimeText = String(format: "%.1f", startTime)
            return
        }
        
        let clampedValue = min(value, audioDuration - 0.5)
        startTime = clampedValue
        
        // Ensure end time is after start time
        if endTime <= startTime {
            endTime = min(startTime + 1, audioDuration)
            endTimeText = String(format: "%.1f", endTime)
        }
        
        // Validate max duration
        if endTime - startTime > maxRingtoneDuration {
            endTime = startTime + maxRingtoneDuration
            endTimeText = String(format: "%.1f", endTime)
            alertTitle = "Duration Adjusted"
            alertMessage = "End time adjusted to maintain 30-second maximum duration."
            showingAlert = true
        }
    }
    
    private func validateAndUpdateEndTime(_ text: String) {
        // Stop playback when changing times
        if isPlaying {
            stopPreview()
        }
        
        // Handle empty input
        if text.isEmpty {
            endTime = min(30, audioDuration)
            return
        }
        
        guard let value = Double(text) else {
            alertTitle = "Invalid Input"
            alertMessage = "Please enter a valid number for end time."
            showingAlert = true
            endTimeText = String(format: "%.1f", endTime)
            return
        }
        
        guard value > 0 else {
            alertTitle = "Invalid Time"
            alertMessage = "End time must be greater than zero."
            showingAlert = true
            endTimeText = String(format: "%.1f", endTime)
            return
        }
        
        guard value <= audioDuration else {
            alertTitle = "Invalid Time"
            alertMessage = "End time cannot exceed song duration (\(formatDuration(audioDuration)))."
            showingAlert = true
            endTimeText = String(format: "%.1f", endTime)
            return
        }
        
        let clampedValue = min(value, audioDuration)
        endTime = clampedValue
        
        // Ensure end time is after start time
        if endTime <= startTime {
            startTime = max(0, endTime - 1)
            startTimeText = String(format: "%.1f", startTime)
            alertTitle = "Time Adjusted"
            alertMessage = "Start time adjusted to be before end time."
            showingAlert = true
        }
        
        // Validate max duration
        if endTime - startTime > maxRingtoneDuration {
            startTime = endTime - maxRingtoneDuration
            startTimeText = String(format: "%.1f", startTime)
            alertTitle = "Duration Adjusted"
            alertMessage = "Start time adjusted to maintain 30-second maximum duration."
            showingAlert = true
        }
    }
    
    private func isValidSelection() -> Bool {
        let duration = endTime - startTime
        return duration > 0 && duration <= maxRingtoneDuration && endTime <= audioDuration && startTime >= 0
    }
    
    private func playPreview() {
        guard let url = selectedAudioURL, isValidSelection() else {
            alertTitle = "Cannot Play"
            alertMessage = "Cannot play preview. Please select a valid audio range."
            showingAlert = true
            return
        }
        
        do {
            // Create audio player
            audioPlayer = try AVAudioPlayer(contentsOf: url)
            audioPlayer?.prepareToPlay()
            
            // Set start time
            audioPlayer?.currentTime = startTime
            
            // Start playing
            audioPlayer?.play()
            isPlaying = true
            
            // Calculate duration to play
            let playDuration = endTime - startTime
            
            // Set up timer to stop at end time
            playbackTimer?.invalidate()
            playbackTimer = Timer.scheduledTimer(withTimeInterval: playDuration, repeats: false) { _ in
                stopPreview()
            }
            
        } catch {
            alertTitle = "Playback Error"
            alertMessage = "Failed to play audio: \(error.localizedDescription)"
            showingAlert = true
            isPlaying = false
        }
    }
    
    private func stopPreview() {
        audioPlayer?.stop()
        audioPlayer = nil
        playbackTimer?.invalidate()
        playbackTimer = nil
        isPlaying = false
    }
    
    private func trimAndExportAudio() {
        guard let asset = audioAsset, isValidSelection() else {
            alertTitle = "Cannot Export"
            alertMessage = "Cannot export. Please select a valid audio range."
            showingAlert = true
            return
        }
        
        // Final check for creation ability
        guard purchaseManager.canCreateRingtone else {
            showingLimitAlert = true
            return
        }
        
        // Stop any playing audio
        stopPreview()
        
        isExporting = true
        exportedFileURL = nil
        
        Task {
            do {
                let exportedURL = try await exportAudioSegment(
                    asset: asset,
                    startTime: startTime,
                    endTime: endTime,
                    songTitle: selectedSongTitle
                )
                
                await MainActor.run {
                    self.exportedFileURL = exportedURL
                    self.isExporting = false
                    
                    // Use a creation (free or ad-unlocked)
                    purchaseManager.useFreeCreation()
                    
                    // Optional: Clean up old ringtones to save space
                    // Uncomment the line below to auto-delete old ringtones
                    // self.cleanupOldRingtones(keepingCurrent: exportedURL)
                    
                    self.alertTitle = "Success"
                    self.alertMessage = "Ringtone created successfully as M4R file! Tap 'Share as Ringtone' to save or share it."
                    self.showingAlert = true
                }
            } catch let error as ExportError {
                await MainActor.run {
                    self.isExporting = false
                    self.alertTitle = "Export Failed"
                    self.alertMessage = error.localizedDescription
                    self.showingAlert = true
                }
            } catch {
                await MainActor.run {
                    self.isExporting = false
                    self.alertTitle = "Export Failed"
                    self.alertMessage = "Failed to create ringtone: \(error.localizedDescription)"
                    self.showingAlert = true
                }
            }
        }
    }
    
    private func exportAudioSegment(asset: AVAsset, startTime: Double, endTime: Double, songTitle: String) async throws -> URL {
        // Ensure duration doesn't exceed 30 seconds
        let duration = endTime - startTime
        let cappedEndTime = startTime + min(duration, maxRingtoneDuration)
        
        // Validate times
        guard startTime >= 0 && cappedEndTime > startTime else {
            throw ExportError.invalidTimeRange
        }
        
        // Create output file URL in documents directory
        let documentsPath = FileManager.default.urls(for: .documentDirectory, in: .userDomainMask)[0]
        let timestamp = Int(Date().timeIntervalSince1970)
        let sanitizedTitle = songTitle.components(separatedBy: CharacterSet.alphanumerics.inverted).joined()
        
        // First export as M4A (required by AVAssetExportSession)
        let tempFileName = "Temp_\(timestamp).m4a"
        let tempURL = documentsPath.appendingPathComponent(tempFileName)
        
        // Final M4R filename
        let ringtoneFileName = "Ringtone_\(sanitizedTitle)_\(timestamp).m4r"
        let ringtoneURL = documentsPath.appendingPathComponent(ringtoneFileName)
        
        // Remove existing files if they exist
        try? FileManager.default.removeItem(at: tempURL)
        try? FileManager.default.removeItem(at: ringtoneURL)
        
        // Create export session
        guard let exportSession = AVAssetExportSession(asset: asset, presetName: AVAssetExportPresetAppleM4A) else {
            throw ExportError.sessionCreationFailed
        }
        
        // Configure export session
        exportSession.outputURL = tempURL
        exportSession.outputFileType = .m4a
        
        // Set time range for trimming (with 30-second cap)
        let start = CMTime(seconds: startTime, preferredTimescale: 600)
        let end = CMTime(seconds: cappedEndTime, preferredTimescale: 600)
        let timeRange = CMTimeRange(start: start, end: end)
        exportSession.timeRange = timeRange
        
        // Perform export
        await exportSession.export()
        
        // Check export status
        switch exportSession.status {
        case .completed:
            // Rename M4A to M4R (they are structurally identical)
            do {
                try FileManager.default.moveItem(at: tempURL, to: ringtoneURL)
                return ringtoneURL
            } catch {
                throw ExportError.fileOperationFailed(error.localizedDescription)
            }
            
        case .failed:
            // Clean up temp file if it exists
            try? FileManager.default.removeItem(at: tempURL)
            
            if let error = exportSession.error {
                throw ExportError.exportFailed(error.localizedDescription)
            } else {
                throw ExportError.unknownError
            }
            
        case .cancelled:
            // Clean up temp file if it exists
            try? FileManager.default.removeItem(at: tempURL)
            throw ExportError.cancelled
            
        default:
            // Clean up temp file if it exists
            try? FileManager.default.removeItem(at: tempURL)
            throw ExportError.unexpectedStatus(exportSession.status.rawValue)
        }
    }
    
    private func getRingtoneURL() -> URL? {
        return exportedFileURL
    }
    
    private func getDocumentsDirectory() -> URL {
        return FileManager.default.urls(for: .documentDirectory, in: .userDomainMask)[0]
    }
    
    private func listExportedRingtones() -> [URL] {
        let documentsPath = getDocumentsDirectory()
        
        do {
            let fileURLs = try FileManager.default.contentsOfDirectory(
                at: documentsPath,
                includingPropertiesForKeys: nil,
                options: .skipsHiddenFiles
            )
            
            // Filter for M4R files
            return fileURLs.filter { $0.pathExtension.lowercased() == "m4r" }
        } catch {
            print("Error listing ringtones: \(error)")
            return []
        }
    }
    
    private func shareRingtone() {
        guard let url = exportedFileURL else {
            alertTitle = "No File"
            alertMessage = "No ringtone file to share."
            showingAlert = true
            return
        }
        
        // Verify file exists
        guard FileManager.default.fileExists(atPath: url.path) else {
            alertTitle = "File Not Found"
            alertMessage = "Ringtone file not found. Please create a new ringtone."
            showingAlert = true
            exportedFileURL = nil
            return
        }
        
        showShareSheet = true
    }
    
    private func openInFiles(url: URL) {
        // This will open the Files app to the location
        // Note: On iOS, this typically opens the share sheet which includes "Save to Files"
        let activityVC = UIActivityViewController(activityItems: [url], applicationActivities: nil)
        activityVC.excludedActivityTypes = [
            .assignToContact,
            .addToReadingList,
            .openInIBooks,
            .markupAsPDF,
            .airDrop,
            .mail,
            .message
        ]
        
        if let windowScene = UIApplication.shared.connectedScenes.first as? UIWindowScene,
           let rootViewController = windowScene.windows.first?.rootViewController {
            rootViewController.present(activityVC, animated: true)
        }
    }
    
    private func deleteExportedFile() {
        guard let url = exportedFileURL else { return }
        
        do {
            try FileManager.default.removeItem(at: url)
            exportedFileURL = nil
            alertTitle = "Success"
            alertMessage = "Ringtone file deleted successfully."
            showingAlert = true
        } catch {
            alertTitle = "Delete Failed"
            alertMessage = "Failed to delete file: \(error.localizedDescription)"
            showingAlert = true
        }
    }
    
    private func cleanupOldRingtones(keepingCurrent currentURL: URL?) {
        let ringtones = listExportedRingtones()
        
        for url in ringtones {
            // Don't delete the current exported file
            if let current = currentURL, url == current {
                continue
            }
            
            // Delete old ringtones (optional: could add age check here)
            try? FileManager.default.removeItem(at: url)
        }
    }
    
    private func requestMediaLibraryAccess() {
        let status = MPMediaLibrary.authorizationStatus()
        
        switch status {
        case .authorized:
            showingMediaPicker = true
        case .notDetermined:
            MPMediaLibrary.requestAuthorization { newStatus in
                DispatchQueue.main.async {
                    if newStatus == .authorized {
                        showingMediaPicker = true
                    } else {
                        alertTitle = "Permission Denied"
                        alertMessage = "Access to media library is required to select songs. Please enable it in Settings > Privacy > Media & Apple Music."
                        showingAlert = true
                    }
                }
            }
        case .denied, .restricted:
            alertTitle = "Permission Required"
            alertMessage = "Please enable media library access in Settings > Privacy > Media & Apple Music to select songs."
            showingAlert = true
        @unknown default:
            alertTitle = "Error"
            alertMessage = "Unable to access media library."
            showingAlert = true
        }
    }
}

// MARK: - Error Types

enum AudioError: LocalizedError {
    case noAudioTrack
    case unsupportedFormat
    case invalidDuration
    case loadFailed(String)
    
    var errorDescription: String? {
        switch self {
        case .noAudioTrack:
            return "No audio track found in the selected file."
        case .unsupportedFormat:
            return "This audio format is not supported. Please select a different song."
        case .invalidDuration:
            return "Unable to determine audio duration. The file may be corrupted."
        case .loadFailed(let message):
            return "Failed to load audio: \(message)"
        }
    }
}

enum ExportError: LocalizedError {
    case invalidTimeRange
    case sessionCreationFailed
    case exportFailed(String)
    case fileOperationFailed(String)
    case cancelled
    case unknownError
    case unexpectedStatus(Int)
    
    var errorDescription: String? {
        switch self {
        case .invalidTimeRange:
            return "Invalid time range selected. Start time must be before end time."
        case .sessionCreationFailed:
            return "Failed to create export session. The audio format may not be supported."
        case .exportFailed(let message):
            return "Export failed: \(message)"
        case .fileOperationFailed(let message):
            return "File operation failed: \(message)"
        case .cancelled:
            return "Export was cancelled."
        case .unknownError:
            return "Export failed with an unknown error. Please try again."
        case .unexpectedStatus(let status):
            return "Export ended with unexpected status code: \(status)"
        }
    }
}

struct MediaPickerView: UIViewControllerRepresentable {
    @Binding var selectedSongTitle: String
    @Binding var selectedAudioURL: URL?
    var onSongSelected: (URL) -> Void
    @Environment(\.presentationMode) var presentationMode
    
    func makeUIViewController(context: Context) -> MPMediaPickerController {
        let picker = MPMediaPickerController(mediaTypes: .music)
        picker.allowsPickingMultipleItems = false
        picker.showsCloudItems = false
        picker.delegate = context.coordinator
        return picker
    }
    
    func updateUIViewController(_ uiViewController: MPMediaPickerController, context: Context) {}
    
    func makeCoordinator() -> Coordinator {
        Coordinator(self)
    }
    
    class Coordinator: NSObject, MPMediaPickerControllerDelegate {
        let parent: MediaPickerView
        
        init(_ parent: MediaPickerView) {
            self.parent = parent
        }
        
        func mediaPicker(_ mediaPicker: MPMediaPickerController, didPickMediaItems mediaItemCollection: MPMediaItemCollection) {
            if let item = mediaItemCollection.items.first {
                let title = item.title ?? "Unknown Title"
                let artist = item.artist ?? "Unknown Artist"
                parent.selectedSongTitle = "\(title) - \(artist)"
                
                // Get the asset URL from the media item
                if let assetURL = item.assetURL {
                    parent.selectedAudioURL = assetURL
                    parent.onSongSelected(assetURL)
                } else {
                    // Handle error: No URL available (e.g., DRM-protected or cloud-only content)
                    DispatchQueue.main.async {
                        self.parent.selectedSongTitle = "Error: Cannot access this song"
                        self.parent.selectedAudioURL = nil
                        
                        // Show alert through a notification or callback
                        NotificationCenter.default.post(
                            name: NSNotification.Name("AudioLoadError"),
                            object: nil,
                            userInfo: ["message": "This song cannot be accessed. It may be DRM-protected or only available in the cloud. Please select a downloaded song from your library."]
                        )
                    }
                }
            }
            parent.presentationMode.wrappedValue.dismiss()
        }
        
        func mediaPickerDidCancel(_ mediaPicker: MPMediaPickerController) {
            parent.presentationMode.wrappedValue.dismiss()
        }
    }
}

// Document Picker for selecting audio files (used in simulator)
struct DocumentPickerView: UIViewControllerRepresentable {
    @Binding var selectedSongTitle: String
    @Binding var selectedAudioURL: URL?
    var onFileSelected: (URL) -> Void
    @Environment(\.presentationMode) var presentationMode
    
    func makeUIViewController(context: Context) -> UIDocumentPickerViewController {
        let picker = UIDocumentPickerViewController(forOpeningContentTypes: [.audio, .mp3, .mpeg4Audio], asCopy: true)
        picker.allowsMultipleSelection = false
        picker.delegate = context.coordinator
        return picker
    }
    
    func updateUIViewController(_ uiViewController: UIDocumentPickerViewController, context: Context) {}
    
    func makeCoordinator() -> Coordinator {
        Coordinator(self)
    }
    
    class Coordinator: NSObject, UIDocumentPickerDelegate {
        let parent: DocumentPickerView
        
        init(_ parent: DocumentPickerView) {
            self.parent = parent
        }
        
        func documentPicker(_ controller: UIDocumentPickerViewController, didPickDocumentsAt urls: [URL]) {
            guard let url = urls.first else { return }
            
            // Get filename
            let filename = url.lastPathComponent
            parent.selectedSongTitle = filename
            parent.selectedAudioURL = url
            parent.onFileSelected(url)
            parent.presentationMode.wrappedValue.dismiss()
        }
        
        func documentPickerWasCancelled(_ controller: UIDocumentPickerViewController) {
            parent.presentationMode.wrappedValue.dismiss()
        }
    }
}

