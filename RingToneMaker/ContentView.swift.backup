//

import SwiftUI
import MediaPlayer
import AVFoundation
import UniformTypeIdentifiers

struct ContentView: View {
    @Bindable var purchaseManager: PurchaseManager
    
    @State private var showingMediaPicker = false
    @State private var showingDocumentPicker = false
    @State private var selectedSongTitle: String = "No song selected"
    @State private var selectedAudioURL: URL?
    @State private var audioAsset: AVAsset?
    @State private var audioDuration: TimeInterval = 0
    @State private var showingAlert = false
    @State private var alertMessage = ""
    @State private var alertTitle = "Notice"
    @State private var isAudioLoaded = false
    
    // Ringtone selection times
    @State private var startTimeText: String = "0"
    @State private var endTimeText: String = "30"
    @State private var startTime: Double = 0
    @State private var endTime: Double = 30
    
    // Audio playback
    @State private var audioPlayer: AVAudioPlayer?
    @State private var isPlaying = false
    @State private var playbackTimer: Timer?
    
    // Export state
    @State private var isExporting = false
    @State private var exportedFileURL: URL?
    @State private var showShareSheet = false
    
    // Monetization UI
    @State private var showingPremiumView = false
    @State private var showingLimitAlert = false
    @State private var showingAdRewardAlert = false
    @State private var showingAdSuccessToast = false
    @State private var adSuccessMessage = ""
    
    private let maxRingtoneDuration: Double = 30
    
    var body: some View {
        NavigationView {
            if isAudioLoaded {
                // Screen 2: Editor Screen (black background, green text, orange waveform)
                ZStack {
                    Color.black.ignoresSafeArea()
                    
                    ScrollView {
                        VStack(spacing: 16) {
                            // Back button and title
                            HStack {
                                Button(action: {
                                    isAudioLoaded = false
                                    selectedAudioURL = nil
                                    audioAsset = nil
                                    selectedSongTitle = "No song selected"
                                    stopPreview()
                                }) {
                                    HStack {
                                        Image(systemName: "chevron.left")
                                        Text("Back")
                                    }
                                    .foregroundColor(.green)
                                }
                                
                                Spacer()
                                
                                Text("Edit Ringtone")
                                    .font(.headline)
                                    .foregroundColor(.green)
                                
                                Spacer()
                                
                                // Placeholder for symmetry
                                HStack {
                                    Image(systemName: "chevron.left")
                                    Text("Back")
                                }
                                .opacity(0)
                            }
                            .padding()
                            
                            // Song title
                            Text(selectedSongTitle)
                                .font(.subheadline)
                                .foregroundColor(.green.opacity(0.7))
                                .lineLimit(1)
                                .padding(.horizontal)
                            
                            // Waveform (orange)
                            if let asset = audioAsset {
                                WaveformView(
                                    audioAsset: asset,
                                    startTime: startTime,
                                    endTime: endTime,
                                    totalDuration: audioDuration
                                )
                                .frame(height: 100)
                                .padding(.horizontal)
                            }
                            
                            // Time controls
                            VStack(spacing: 12) {
                                HStack {
                                    VStack(alignment: .leading) {
                                        Text("Start")
                                            .font(.caption)
                                            .foregroundColor(.green.opacity(0.7))
                                        TextField("0", text: $startTimeText)
                                            .textFieldStyle(RoundedBorderTextFieldStyle())
                                            .keyboardType(.decimalPad)
                                            .frame(width: 60)
                                    }
                                    
                                    Spacer()
                                    
                                    VStack(alignment: .trailing) {
                                        Text("End")
                                            .font(.caption)
                                            .foregroundColor(.green.opacity(0.7))
                                        TextField("30", text: $endTimeText)
                                            .textFieldStyle(RoundedBorderTextFieldStyle())
                                            .keyboardType(.decimalPad)
                                            .frame(width: 60)
                                    }
                                }
                                
                                Text("Duration: \(formatDuration(endTime - startTime))")
                                    .font(.caption)
                                    .foregroundColor(.green)
                            }
                            .padding()
                            .background(Color.green.opacity(0.1))
                            .overlay(
                                RoundedRectangle(cornerRadius: 12)
                                    .stroke(Color.green.opacity(0.3), lineWidth: 1)
                            )
                            .clipShape(RoundedRectangle(cornerRadius: 12))
                            .padding(.horizontal)
                            
                            // Export button
                            Button(action: {
                                handleExportAction()
                            }) {
                                HStack {
                                    if isExporting {
                                        ProgressView()
                                            .progressViewStyle(CircularProgressViewStyle(tint: .black))
                                        Text("Creating...")
                                    } else {
                                        Image(systemName: "scissors")
                                        Text("Create Ringtone")
                                    }
                                }
                                .font(.headline)
                                .foregroundColor(.black)
                                .frame(maxWidth: .infinity)
                                .padding()
                                .background(Color.green)
                                .clipShape(RoundedRectangle(cornerRadius: 12))
                            }
                            .disabled(isExporting || (endTime - startTime) > maxRingtoneDuration)
                            .padding(.horizontal)
                            
                            Spacer()
                        }
                    }
                }
                .navigationBarHidden(true)
            } else {
                // Screen 1: Selection Screen
                SelectionScreen(
                    purchaseManager: purchaseManager,
                    selectedSongTitle: $selectedSongTitle,
                    showingMediaPicker: $showingMediaPicker,
                    showingDocumentPicker: $showingDocumentPicker,
                    showingPremiumView: $showingPremiumView,
                    requestMediaLibraryAccess: requestMediaLibraryAccess
                )
            }
        }
        .sheet(isPresented: $showingMediaPicker) {
            MediaPickerView(
                selectedSongTitle: $selectedSongTitle,
                selectedAudioURL: $selectedAudioURL,
                onSongSelected: { url in
                    loadAudioAsset(from: url)
                }
            )
        }
        .sheet(isPresented: $showingDocumentPicker) {
            DocumentPickerView(
                selectedSongTitle: $selectedSongTitle,
                selectedAudioURL: $selectedAudioURL,
                onFileSelected: { url in
                    loadAudioAsset(from: url)
                }
            )
        }
        .alert(alertTitle, isPresented: $showingAlert) {
            Button("OK", role: .cancel) { }
        } message: {
            Text(alertMessage)
        }
        .onReceive(NotificationCenter.default.publisher(for: NSNotification.Name("AudioLoadError"))) { notification in
            if let message = notification.userInfo?["message"] as? String {
                alertMessage = message
                showingAlert = true
            }
        }
        .onDisappear {
            stopPreview()
        }
        .sheet(isPresented: $showShareSheet) {
            if let url = exportedFileURL {
                ShareSheet(items: [url]) {
                    print("Share sheet dismissed")
                }
            }
        }
        .sheet(isPresented: $showingPremiumView) {
            PurchaseView(purchaseManager: purchaseManager)
        }
    }
    
    // MARK: - Premium Status Banner
    
    private var premiumStatusBanner: some View {
                                    .foregroundColor(.secondary)
                            }
                            .padding(.horizontal, 16)
                            
                            // Waveform visualization
                            VStack(alignment: .leading, spacing: 6) {
                                HStack {
                                    Text("Waveform")
                                        .font(.caption)
                                        .fontWeight(.semibold)
                                    
                                    Spacer()
                                    
                                    // Preview play button
                                    Button(action: {
                                        if isPlaying {
                                            stopPreview()
                                        } else {
                                            playPreview()
                                        }
                                    }) {
                                        HStack(spacing: 3) {
                                            Image(systemName: isPlaying ? "stop.fill" : "play.fill")
                                                .font(.caption2)
                                            Text(isPlaying ? "Stop" : "Preview")
                                                .font(.caption2)
                                        }
                                        .foregroundColor(.white)
                                        .padding(.horizontal, 12)
                                        .padding(.vertical, 6)
                                        .background(isPlaying ? Color.red : Color.green)
                                        .clipShape(RoundedRectangle(cornerRadius: 15))
                                    }
                                    .disabled(!isValidSelection())
                                }
                                .padding(.horizontal, 16)
                                
                                WaveformView(
                                    audioAsset: asset,
                                    startTime: startTime,
                                    endTime: endTime,
                                    totalDuration: audioDuration
                                )
                                .frame(height: 80)
                                .padding(.horizontal, 16)
                                
                                HStack(spacing: 12) {
                                    HStack(spacing: 3) {
                                        Image(systemName: "magnifyingglass")
                                            .font(.system(size: 8))
                                        Text("Pinch to zoom")
                                            .font(.system(size: 9))
                                    }
                                    .foregroundColor(.secondary)
                                    
                                    HStack(spacing: 3) {
                                        Image(systemName: "hand.draw")
                                            .font(.system(size: 8))
                                        Text("Drag to pan")
                                            .font(.system(size: 9))
                                    }
                                    .foregroundColor(.secondary)
                                }
                                .padding(.horizontal, 16)
                                
                                Text("Blue section = ringtone")
                                    .font(.system(size: 10))
                                    .foregroundColor(.secondary)
                                    .padding(.horizontal, 16)
                            }
                            
                            // Time selection controls
                            VStack(spacing: 10) {
                                Text("Select Duration")
                                    .font(.subheadline)
                                    .fontWeight(.semibold)
                                
                                HStack(spacing: 12) {
                                    // Start time
                                    VStack(alignment: .leading, spacing: 4) {
                                        Text("Start (sec)")
                                            .font(.system(size: 10))
                                            .foregroundColor(.secondary)
                                        
                                        HStack(spacing: 6) {
                                            TextField("0", text: $startTimeText)
                                                .textFieldStyle(RoundedBorderTextFieldStyle())
                                                .keyboardType(.decimalPad)
                                                .frame(width: 50)
                                                .font(.caption)
                                                .onChange(of: startTimeText) { newValue in
                                                    validateAndUpdateStartTime(newValue)
                                                }
                                            
                                            Stepper("", value: Binding(
                                                get: { startTime },
                                                set: { newValue in
                                                    startTime = max(0, min(newValue, audioDuration - 1))
                                                    startTimeText = String(format: "%.1f", startTime)
                                                    if endTime <= startTime {
                                                        endTime = min(startTime + 1, audioDuration)
                                                        endTimeText = String(format: "%.1f", endTime)
                                                    }
                                                }
                                            ), in: 0...max(0, audioDuration - 1), step: 0.5)
                                            .labelsHidden()
                                            .scaleEffect(0.8)
                                        }
                                        
                                        // Start time slider
                                        Slider(
                                            value: Binding(
                                                get: { startTime },
                                                set: { newValue in
                                                    startTime = newValue
                                                    startTimeText = String(format: "%.1f", startTime)
                                                    if endTime <= startTime {
                                                        endTime = min(startTime + 1, audioDuration)
                                                        endTimeText = String(format: "%.1f", endTime)
                                                    }
                                                }
                                            ),
                                            in: 0...max(0, audioDuration - 1),
                                            step: 0.1
                                        )
                                        .accentColor(.blue)
                                    }
                                    
                                    // End time
                                    VStack(alignment: .leading, spacing: 4) {
                                        Text("End (sec)")
                                            .font(.system(size: 10))
                                            .foregroundColor(.secondary)
                                        
                                        HStack(spacing: 6) {
                                            TextField("30", text: $endTimeText)
                                                .textFieldStyle(RoundedBorderTextFieldStyle())
                                                .keyboardType(.decimalPad)
                                                .frame(width: 50)
                                                .font(.caption)
                                                .onChange(of: endTimeText) { newValue in
                                                    validateAndUpdateEndTime(newValue)
                                                }
                                            
                                            Stepper("", value: Binding(
                                                get: { endTime },
                                                set: { newValue in
                                                    endTime = max(startTime + 0.5, min(newValue, audioDuration))
                                                    endTimeText = String(format: "%.1f", endTime)
                                                }
                                            ), in: (startTime + 0.5)...audioDuration, step: 0.5)
                                            .labelsHidden()
                                            .scaleEffect(0.8)
                                        }
                                        
                                        // End time slider
                                        Slider(
                                            value: Binding(
                                                get: { endTime },
                                                set: { newValue in
                                                    endTime = newValue
                                                    endTimeText = String(format: "%.1f", endTime)
                                                    if endTime <= startTime {
                                                        startTime = max(0, endTime - 1)
                                                        startTimeText = String(format: "%.1f", startTime)
                                                    }
                                                }
                                            ),
                                            in: 0...audioDuration,
                                            step: 0.1
                                        )
                                        .accentColor(.green)
                                    }
                                }
                                .padding(.horizontal, 16)
                                
                                // Duration info
                                let duration = endTime - startTime
                                HStack(spacing: 6) {
                                    Text("Duration: \(formatDuration(duration))")
                                        .font(.caption)
                                        .foregroundColor(duration <= maxRingtoneDuration ? .primary : .red)
                                    
                                    if duration > maxRingtoneDuration {
                                        Image(systemName: "exclamationmark.triangle.fill")
                                            .foregroundColor(.red)
                                            .font(.caption2)
                                    } else if duration > 0 {
                                        Image(systemName: "checkmark.circle.fill")
                                            .foregroundColor(.green)
                                            .font(.caption2)
                                    }
                                }
                                .padding(.horizontal, 16)
                                
                                if duration > maxRingtoneDuration {
                                    Text("Max 30 seconds")
                                        .font(.system(size: 10))
                                        .foregroundColor(.red)
                                        .padding(.horizontal, 16)
                                }
                                
                                if endTime > audioDuration {
                                    Text("End time exceeds song duration")
                                        .font(.system(size: 10))
                                        .foregroundColor(.red)
                                        .padding(.horizontal, 16)
                                }
                            }
                            .padding(.vertical, 8)
                            .background(Color.gray.opacity(0.05))
                            .clipShape(RoundedRectangle(cornerRadius: 15))
                            .padding(.horizontal, 16)
                            
                            // Export button (placeholder for future implementation)
                            exportButton
                            
                            // Watch ads button (if needed)
                            if purchaseManager.needsToWatchAdsOrUpgrade && !purchaseManager.isPremium {
                                watchAdsButton
                            }
                            
                            // Upgrade button (if not premium)
                            if !purchaseManager.isPremium {
                                upgradeButton
                            }
                            
                            if let exportedURL = exportedFileURL {
                                VStack(spacing: 10) {
                                    HStack {
                                        Image(systemName: "checkmark.circle.fill")
                                            .foregroundColor(.green)
                                        Text("Ringtone created successfully!")
                                            .font(.subheadline)
                                            .foregroundColor(.green)
                                    }
                                    
                                    HStack(spacing: 8) {
                                        Image(systemName: "music.note")
                                            .foregroundColor(.blue)
                                        Text("M4R Format")
                                            .font(.caption)
                                            .foregroundColor(.blue)
                                            .fontWeight(.semibold)
                                    }
                                    .padding(.horizontal, 12)
                                    .padding(.vertical, 6)
                                    .background(Color.blue.opacity(0.1))
                                    .clipShape(RoundedRectangle(cornerRadius: 15))
                                    
                                    Button(action: {
                                        shareRingtone()
                                    }) {
                                        HStack {
                                            Image(systemName: "square.and.arrow.up")
                                            Text("Share as Ringtone")
                                        }
                                        .font(.subheadline)
                                        .foregroundColor(.white)
                                        .frame(maxWidth: .infinity)
                                        .padding()
                                        .background(Color.blue)
                                        .clipShape(RoundedRectangle(cornerRadius: 15))
                                    }
                                    
                                    HStack(spacing: 15) {
                                        Button(action: {
                                            if let url = exportedFileURL {
                                                openInFiles(url: url)
                                            }
                                        }) {
                                            VStack(spacing: 4) {
                                                Image(systemName: "folder")
                                                    .font(.title3)
                                                Text("Open in Files")
                                                    .font(.caption2)
                                            }
                                            .foregroundColor(.blue)
                                            .frame(maxWidth: .infinity)
                                            .padding(.vertical, 8)
                                            .background(Color.blue.opacity(0.1))
                                            .clipShape(RoundedRectangle(cornerRadius: 15))
                                        }
                                        
                                        Button(action: {
                                            deleteExportedFile()
                                        }) {
                                            VStack(spacing: 4) {
                                                Image(systemName: "trash")
                                                    .font(.title3)
                                                Text("Delete")
                                                    .font(.caption2)
                                            }
                                            .foregroundColor(.red)
                                            .frame(maxWidth: .infinity)
                                            .padding(.vertical, 8)
                                            .background(Color.red.opacity(0.1))
                                            .clipShape(RoundedRectangle(cornerRadius: 15))
                                        }
                                    }
                                    
                                    Text("File: \(exportedURL.lastPathComponent)")
                                        .font(.caption)
                                        .foregroundColor(.secondary)
                                    
                                    Text("Duration: \(formatDuration(min(endTime - startTime, maxRingtoneDuration)))")
                                        .font(.caption)
                                        .foregroundColor(.secondary)
                                }
                                .padding()
                                .background(Color.green.opacity(0.1))
                                .clipShape(RoundedRectangle(cornerRadius: 15))
                                .padding(.horizontal, 16)
                            }
                        }
                    } else if !isAudioLoaded {
                        Text("Select a song to create your custom ringtone")
                            .font(.caption)
                            .foregroundColor(.secondary)
                            .multilineTextAlignment(.center)
                            .padding()
                    }
                    
                    Spacer(minLength: 20)
                    }
                }
            }
            .navigationTitle("RingTone Maker")
            .navigationBarTitleDisplayMode(.inline)
            .sheet(isPresented: $showingMediaPicker) {
                MediaPickerView(
                    selectedSongTitle: $selectedSongTitle,
                    selectedAudioURL: $selectedAudioURL,
                    onSongSelected: { url in
                        loadAudioAsset(from: url)
                    }
                )
            }
            .sheet(isPresented: $showingDocumentPicker) {
                DocumentPickerView(
                    selectedSongTitle: $selectedSongTitle,
                    selectedAudioURL: $selectedAudioURL,
                    onFileSelected: { url in
                        loadAudioAsset(from: url)
                    }
                )
            }
            .alert(alertTitle, isPresented: $showingAlert) {
                Button("OK", role: .cancel) { }
            } message: {
                Text(alertMessage)
            }
            .onReceive(NotificationCenter.default.publisher(for: NSNotification.Name("AudioLoadError"))) { notification in
                if let message = notification.userInfo?["message"] as? String {
                    alertMessage = message
                    showingAlert = true
                }
            }
            .onDisappear {
                // Clean up audio player when view disappears
                stopPreview()
            }
            .sheet(isPresented: $showShareSheet) {
                if let url = exportedFileURL {
                    ShareSheet(items: [url]) {
                        // Optional: Handle post-share actions
                        print("Share sheet dismissed")
                    }
                }
            }
            .sheet(isPresented: $showingPremiumView) {
                PurchaseView(purchaseManager: purchaseManager)
            }
            .alert("Limit Reached", isPresented: $showingLimitAlert) {
                Button("Watch Ads", role: .none) {
                    watchRewardedAd()
                }
                Button("Go Premium", role: .none) {
                    showingPremiumView = true
                }
                Button("Cancel", role: .cancel) { }
            } message: {
                Text("You've used your 3 free ringtone creations. Watch 3 ads to unlock 1 more, or upgrade to Premium for unlimited creations.")
            }
            .alert("Ad Reward", isPresented: $showingAdRewardAlert) {
                Button("OK", role: .cancel) { }
            } message: {
                Text("Great! You've watched \(purchaseManager.adsWatchedForNextUnlock)/3 ads. \(purchaseManager.adsWatchedForNextUnlock >= 3 ? "You've unlocked 1 ringtone!" : "Watch \(3 - purchaseManager.adsWatchedForNextUnlock) more to unlock 1 ringtone.")")
            }
            .overlay(alignment: .top) {
                // Success toast
                if showingAdSuccessToast {
                    VStack {
                        HStack(spacing: 12) {
                            Image(systemName: "checkmark.circle.fill")
                                .foregroundColor(.white)
                                .font(.title3)
                            
                            Text(adSuccessMessage)
                                .font(.subheadline)
                                .fontWeight(.medium)
                                .foregroundColor(.white)
                        }
                        .padding()
                        .background(Color.green)
                        .clipShape(RoundedRectangle(cornerRadius: 15))
                        .shadow(radius: 10)
                        .padding(.top, 60)
                    }
                    .transition(.move(edge: .top).combined(with: .opacity))
                    .animation(.spring(), value: showingAdSuccessToast)
                }
            }
            .navigationTitle("RingTone Maker")
            .navigationBarTitleDisplayMode(.inline)
            .sheet(isPresented: $showingMediaPicker) {
                MediaPickerView(
                    selectedSongTitle: $selectedSongTitle,
                    selectedAudioURL: $selectedAudioURL,
                    onSongSelected: { url in
                        loadAudioAsset(from: url)
                    }
                )
            }
            .sheet(isPresented: $showingDocumentPicker) {
                DocumentPickerView(
                    selectedSongTitle: $selectedSongTitle,
                    selectedAudioURL: $selectedAudioURL,
                    onFileSelected: { url in
                        loadAudioAsset(from: url)
                    }
                )
            }
            .alert(alertTitle, isPresented: $showingAlert) {
                Button("OK", role: .cancel) { }
            } message: {
                Text(alertMessage)
            }
        }
    }
    
    // MARK: - Premium Status Banner
    
    private var premiumStatusBanner: some View {
        VStack(spacing: 10) {
            if purchaseManager.remainingFreeCreations > 0 {
                HStack(spacing: 12) {
                    ZStack {
                        Circle()
                            .fill(Color.blue.opacity(0.2))
                            .frame(width: 40, height: 40)
                        
                        Image(systemName: "gift.fill")
                            .foregroundColor(.blue)
                    }
                    
                    VStack(alignment: .leading, spacing: 2) {
                        Text("\(purchaseManager.remainingFreeCreations) Free Ringtones")
                            .font(.subheadline)
                            .fontWeight(.semibold)
                        Text("Create \(purchaseManager.remainingFreeCreations) more for free")
                            .font(.caption)
                            .foregroundColor(.secondary)
                    }
                    
                    Spacer()
                    
                    Button(action: {
                        showingPremiumView = true
                    }) {
                        Text("Premium")
                            .font(.caption)
                            .fontWeight(.semibold)
                            .foregroundColor(.blue)
                            .padding(.horizontal, 12)
                            .padding(.vertical, 6)
                            .background(Color.blue.opacity(0.15))
                            .clipShape(Capsule())
                    }
                }
                .padding()
                .background(Color.white)
                .clipShape(RoundedRectangle(cornerRadius: 16))
                .shadow(color: .black.opacity(0.08), radius: 8, x: 0, y: 4)
            }
            
            if purchaseManager.extraCreationsAvailable > 0 {
                HStack(spacing: 12) {
                    ZStack {
                        Circle()
                            .fill(Color.green.opacity(0.2))
                            .frame(width: 40, height: 40)
                        
                        Image(systemName: "checkmark.circle.fill")
                            .foregroundColor(.green)
                    }
                    
                    VStack(alignment: .leading, spacing: 2) {
                        Text("\(purchaseManager.extraCreationsAvailable) Unlocked")
                            .font(.subheadline)
                            .fontWeight(.semibold)
                        Text("Earned by watching ads")
                            .font(.caption)
                            .foregroundColor(.secondary)
                    }
                    
                    Spacer()
                }
                .padding()
                .background(Color.white)
                .clipShape(RoundedRectangle(cornerRadius: 16))
                .shadow(color: .black.opacity(0.08), radius: 8, x: 0, y: 4)
            }
            
            if purchaseManager.adsWatchedForNextUnlock > 0 && !purchaseManager.isPremium {
                VStack(spacing: 8) {
                    HStack(spacing: 12) {
                        ZStack {
                            Circle()
                                .fill(Color.orange.opacity(0.2))
                                .frame(width: 40, height: 40)
                            
                            Image(systemName: "tv.fill")
                                .foregroundColor(.orange)
                        }
                        
                        VStack(alignment: .leading, spacing: 2) {
                            Text("Next Unlock Progress")
                                .font(.subheadline)
                                .fontWeight(.semibold)
                            Text("\(purchaseManager.adsWatchedForNextUnlock)/3 ads watched")
                                .font(.caption)
                                .foregroundColor(.secondary)
                        }
                        
                        Spacer()
                    }
                    
                    ProgressView(value: purchaseManager.adUnlockProgress)
                        .tint(.orange)
                }
                .padding()
                .background(Color.white)
                .clipShape(RoundedRectangle(cornerRadius: 16))
                .shadow(color: .black.opacity(0.08), radius: 8, x: 0, y: 4)
            }
        }
    }
    
    // MARK: - Export Button
    
    private var exportButton: some View {
        Button(action: {
            handleExportAction()
        }) {
            HStack {
                if isExporting {
                    ProgressView()
                        .progressViewStyle(CircularProgressViewStyle(tint: .white))
                    Text("Creating Ringtone...")
                } else {
                    Image(systemName: "scissors")
                    exportButtonText
                }
            }
            .font(.headline)
            .foregroundColor(.white)
            .frame(maxWidth: .infinity)
            .padding()
            .background(exportButtonColor)
            .clipShape(RoundedRectangle(cornerRadius: 15))
        }
        .disabled(!isValidSelection() || isExporting)
        .padding(.horizontal, 20)
    }
    
    private var exportButtonText: Text {
        if purchaseManager.isPremium {
            return Text("Export Ringtone (Unlimited)")
        } else if purchaseManager.remainingFreeCreations > 0 {
            return Text("Export Ringtone (\(purchaseManager.remainingFreeCreations) free left)")
        } else if purchaseManager.extraCreationsAvailable > 0 {
            return Text("Export Ringtone (\(purchaseManager.extraCreationsAvailable) unlocked)")
        } else {
            return Text("Upgrade or Watch Ads")
        }
    }
    
    private var exportButtonColor: Color {
        if !isValidSelection() || isExporting {
            return Color.gray
        } else if purchaseManager.canCreateRingtone {
            return Color.green
        } else {
            return Color.orange
        }
    }
    
    // MARK: - Watch Ads Button
    
